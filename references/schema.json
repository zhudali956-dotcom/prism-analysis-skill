{
  "framework": "棱镜分析 / Prism Analysis Framework",
  "version": "1.0",
  "description": "一个从多维度审视研究对象的多层分析框架。搜索层采用分级多轮递进体系，分析层从起源、分野、格局、推演四个维度展开，输出层以叙事驱动呈现。",

  "meta": {
    "研究对象": {
      "名称": "string",
      "类型": "产品 | 公司 | 概念 | 人物 | 其他",
      "一句话定义": "string",
      "所属领域": "string",
      "研究发起日期": "date",
      "研究动机": "string — 为什么在这个时间点研究它",
      "特别关注点": ["string — 用户指定的重点关注方向"]
    }
  },

  "搜索层_信息勘探": {
    "description": "四轮递进搜索：宽泛扫描 → 定向深挖 → 可信度验证 → 补漏追根",

    "第一轮_宽泛扫描": {
      "搜索方向": [
        {
          "方向": "起源与历程",
          "子Agent": "A",
          "发现的关键线索": ["string"],
          "已覆盖的信息范围": "string",
          "初步信息缺口": ["string"]
        },
        {
          "方向": "行业与竞争",
          "子Agent": "B",
          "发现的关键线索": ["string"],
          "已覆盖的信息范围": "string",
          "初步信息缺口": ["string"]
        },
        {
          "方向": "原理与定位",
          "子Agent": "C",
          "发现的关键线索": ["string"],
          "已覆盖的信息范围": "string",
          "初步信息缺口": ["string"]
        }
      ]
    },

    "第二轮_定向深挖": {
      "识别出的信息缺口": ["string"],
      "缺口补充结果": [
        {
          "缺口": "string",
          "补充方式": "string — 用了什么来源和渠道",
          "补充结果": "string",
          "是否补足": "boolean"
        }
      ]
    },

    "第三轮_可信度验证": {
      "验证方法": "string — 交叉验证流程说明",
      "关键事实与可信度": [
        {
          "事实": "string",
          "可信度等级": "A级 | B级 | C级 | D级 | 无法验证",
          "来源1": "string",
          "来源2": "string | null",
          "是否通过验证": "boolean",
          "备注": "string"
        }
      ]
    },

    "第四轮_补漏追根": {
      "逻辑断层检测": ["string"],
      "补漏结果": "string",
      "最终信息充分度评估": "充分 | 基本充分 | 有缺口但已标注 | 不充分"
    }
  },

  "分析层_四维解构": {
    "description": "起源（时间线叙事）→ 分野（岔路口对比）→ 格局（当前位势）→ 推演（未来场景），按认知深度递进",

    "起源_发展轨迹": {
      "description": "一整篇连贯的叙事，不使用层级标题。以下字段是作者的分析笔记，不是报告结构。",

      "起源笔记": {
        "诞生背景_PEST扫描": {
          "政治/政策": "string",
          "经济": "string",
          "社会": "string",
          "技术": "string"
        },
        "创始团队与初始愿景": "string",
        "诞生的具体时间与最初形态": "string",
        "为什么是这个时候/这些人": "string"
      },

      "事件流": [
        {
          "事件": "string — 发生了什么",
          "时间": "date",
          "为什么重要": "string — 这个事件如何改变了走向",
          "决策逻辑": {
            "为什么这么选": "string",
            "替代方案": "string",
            "约束条件": "string"
          },
          "连锁反应": {
            "锁定的路径": "string",
            "反事实": "string — 如果选了另一条路",
            "今日回望": "string"
          }
        }
      ],

      "阶段转换": {
        "说明": "阶段之间的过渡用叙事句完成，不出现层级标题",
        "转换句式示例": ["但到了X年，风向变了...", "转折点出现在...", "如果前三年是...那X年就是..."],
        "阶段划分笔记": [
          {
            "阶段名称": "string — 仅作者可见",
            "时间跨度": "string",
            "核心特征": "string",
            "核心矛盾": "string"
          }
        ]
      },

      "叙事检验": {
        "读起来像深度报道还是章节报告？": "深度报道 | 章节报告",
        "有没有使用层级标题？": "是 | 否",
        "是否每个事件都有「为什么」的追问？": "是 | 否",
        "阶段转换是否自然过渡？": "是 | 否"
      }
    },

    "分野_岔路口": {
      "description": "在关键时间节点上，把研究对象和竞品放到同一帧画面里对比选择路径",

      "关键岔路口": [
        {
          "时间节点": "string",
          "背景环境": "string — 当时发生了什么",
          "研究对象的决策": {
            "选择": "string",
            "决策逻辑": "string",
            "约束条件": "string"
          },
          "竞品A的决策": {
            "竞品名称": "string",
            "选择": "string",
            "决策逻辑": "string",
            "为什么不同": "string — 与研究对象的路径差异原因"
          },
          "竞品B的决策": {
            "竞品名称": "string",
            "选择": "string",
            "决策逻辑": "string",
            "为什么不同": "string"
          },
          "路径差异后果": "string — 这些选择如何导致了今天的能力差异",
          "反事实": "string — 如果选了另一条路会怎样"
        }
      ]
    },

    "格局_当前位势": {
      "description": "当前时间截面的全景对比",

      "分析时间截面": "date",
      "竞品场景判断": "场景A（无直接竞品） | 场景B（少量竞品） | 场景C（竞品充分）",

      "研究对象当前画像": {
        "定位": "string",
        "核心能力": ["string"],
        "核心短板": ["string"],
        "目标用户": "string",
        "商业模式": "string",
        "技术路线": "string",
        "规模体量": "string"
      },

      "三维竞争分析": {
        "产品与技术维": [
          {
            "对比项": "string — 如'核心方法论'、'性能指标'",
            "研究对象": "string",
            "竞品A": "string",
            "竞品B": "string",
            "洞察": "string — 这个差异说明了什么"
          }
        ],
        "市场与生态维": [
          {
            "对比项": "string — 如'用户画像'、'增长轨迹'",
            "研究对象": "string",
            "竞品A": "string",
            "竞品B": "string",
            "洞察": "string"
          }
        ],
        "护城河分析": [
          {
            "竞争者": "string",
            "核心壁垒": "string",
            "壁垒类型": "网络效应 | 技术壁垒 | 品牌壁垒 | 规模壁垒 | 转换成本",
            "壁垒强度": "强 | 中 | 弱",
            "可能被打破的条件": "string"
          }
        ]
      },

      "优势溯源": [
        {
          "当前优势": "string",
          "根源岔路口": "string — 追溯到哪个时间点的哪个决策",
          "是否可持续": "是 | 否 | 取决于"
        }
      ],

      "劣势溯源": [
        {
          "当前劣势": "string",
          "根源岔路口": "string — 追溯到哪个时间点的哪个决策",
          "是否可逆转": "是 | 否 | 取决于"
        }
      ]
    },

    "推演_变量与场景": {
      "description": "面向未来的不确定性分析",

      "关键变量识别": [
        {
          "变量": "string",
          "变化方向": ["string"],
          "不确定性程度": "高 | 中 | 低",
          "影响力": "高 | 中 | 低"
        }
      ],

      "场景分析": [
        {
          "场景名称": "string",
          "变量组合": "string — 哪些变量走向何种方向",
          "逻辑推演链": "string — 为什么这个场景会发生",
          "概率评估": "高 | 中 | 低",
          "早期信号": ["string — 如果发生会有什么迹象"],
          "行动建议": ["string — 可以提前做什么"]
        }
      ],

      "最终判断": "string — 综合后给出的结论性观点"
    }
  },

  "输出层_叙事呈现": {
    "报告结构": [
      "一句话定义",
      "起源：起点与轨迹",
      "分野：岔路口的选择",
      "格局：当下的位势",
      "推演：变量与场景",
      "信息来源"
    ],
    "字数建议": {
      "起源（时间线叙事）": "4,000 - 8,000字",
      "分野（岔路口对比）": "2,000 - 4,000字",
      "格局（当前位势）": "2,000 - 5,000字",
      "推演（未来场景）": "1,500 - 3,000字",
      "全文总计": "10,000 - 25,000字"
    },
    "输出格式": ["PDF（排版精美）", "Markdown（源文件）"],
    "信息来源标注": "所有关键事实需标注来源和可信度等级"
  }
}
